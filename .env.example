# API Configuration
API_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Typesense Configuration
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-typesense-api-key

# Constitution Scraping Configuration
CONSTITUTION_URL=https://www.planalto.gov.br/ccivil_03/constituicao/ConstituicaoCompilado.htm
CONSTITUTION_COLLECTION_NAME=brazilian_constitution_v1
INDEXING_BATCH_SIZE=200

# Health Check Configuration
MEMORY_HEAP_THRESHOLD_MB=150
MEMORY_RSS_THRESHOLD_MB=150
DISK_THRESHOLD_PERCENT=0.9

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache Configuration
CACHE_TTL=3600

# Rate Limiting Configuration
RATE_LIMIT_SHORT_TTL=60000
RATE_LIMIT_SHORT_LIMIT=10
RATE_LIMIT_MEDIUM_TTL=600000
RATE_LIMIT_MEDIUM_LIMIT=50
RATE_LIMIT_LONG_TTL=3600000
RATE_LIMIT_LONG_LIMIT=100

# Logging Configuration
LOG_LEVEL=info
NODE_ENV=development

# Authentication Configuration
JWT_SECRET=constitution-search-secret-key-change-in-production
JWT_EXPIRES_IN=3600
ADMIN_DEFAULT_PASSWORD=admin123
USER_DEFAULT_PASSWORD=user123



# Streaming Parser Configuration
STREAMING_CHUNK_SIZE=8192
STREAMING_MAX_MEMORY_MB=50

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PATH=/metrics
